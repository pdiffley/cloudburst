{
  "name": "@cloudburst-dev/web",
  "version": "0.1.0",
  "description": "Cloudburst client library",
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "default": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "scripts": {
    "check:format": "npx prettier --check .",
    "check:lint": "npx eslint .",
    "check:types": "npx tsc --emitDeclarationOnly",
    "fix:format": "npx prettier --write .",
    "fix:lint": "npx eslint --fix .",
    "build": "npx tsc",
    "prepack": "npm run build",
    "gen:ref": "typedoc"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@tsconfig/strictest": "^2.0.7",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript-eslint": "^8.46.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@esfx/async-mutex": "^1.0.0",
    "@eslint/compat": "^1.4.1",
    "@types/uuid": "^10.0.0",
    "async-mutex": "^0.5.0",
    "jwt-decode": "^4.0.0",
    "uuid": "^13.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
